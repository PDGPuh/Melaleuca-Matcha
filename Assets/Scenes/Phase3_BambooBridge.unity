--- !u!114 &1461731753
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1461731752}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: f53b7895a0d81e04cbda064ec235f58f, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::RungTramTraSu.NPCGrandpa
  introDialogue:
  - "D\u1EADy r\u1ED3i \u0111\xF3 h\u1EA3 con? \u0110\xEAm qua ng\u1EE7 ngon gi\u1EA5c
    kh\xF4ng?"
  - "S\xE1ng nay tr\u1EDDi m\xE1t m\u1EBB d\u1EEF l\u1EAFm. \xD4ng ngo\u1EA1i chu\u1EA9n
    b\u1ECB xu\u1ED3ng s\u1EB5n r\u1ED3i, l\xE1t hai \xF4ng ch\xE1u m\xECnh \u0111i
    ch\u01A1i r\u1EEBng tr\xE0m Tr\xE0 S\u01B0 nghe."
  - "M\xE0 n\xE8, \xF4ng ngo\u1EA1i c\xF3 c\xE1i n\xE0y cho con..."
  - "\u0110\xE2y l\xE0 chi\u1EBFc m\xE1y \u1EA3nh phim c\u0169 c\u1EE7a \xF4ng h\u1ED3i
    x\u01B0a. Con gi\u1EEF l\u1EA5y \u0111i."
  - "\u0110i ch\u01A1i r\u1EEBng \u0111\u1EB9p l\u1EAFm, con c\u1EA7m m\xE1y theo
    ch\u1EE5p l\u1EA1i l\xE0m k\u1EF7 ni\u1EC7m."
  - "N\xE8, con th\u1EED c\u1EA7m l\xEAn, b\u1EA5m chu\u1ED9t ph\u1EA3i \u0111\u1EC3
    ng\u1EAFm ng\u1ED1c r\u1ED3i ch\u1EE5p th\u1EED c\xE2y xo\xE0i to \u0111\u1EB1ng
    kia cho \xF4ng xem coi c\xF3 ho\u1EA1t \u0111\u1ED9ng t\u1ED1t kh\xF4ng nha!"
  waitingForPhotoDialogue:
  - "Con c\u1EE9 t\u1EEB t\u1EEB th\u1EED xem. Nh\u1EA5n chu\u1ED9t ph\u1EA3i \u0111\u1EC3
    ng\u1EAFm (Zoom) v\xE0 click chu\u1ED9t tr\xE1i \u0111\u1EC3 ch\u1EE5p c\xE2y
    xo\xE0i to \u0111\u1EB1ng kia k\xECa."
  - "Th\u1EED ch\u1EE5p m\u1ED9t t\u1EA5m \u0111\u1EB9p \u0111\u1EB9p cho \xF4ng
    coi th\u1EED coi."
  photoTakenDialogue:
  - "\u0110\xE2u, \u0111\u01B0a \xF4ng coi t\u1EA5m h\xECnh th\u1EED... \u1EEAa!
    \u0110\u1EB9p l\u1EAFm con, m\xE1y \u1EA3nh c\u0169 v\u1EADy ch\u1EE9 ch\u1EE5p
    v\u1EABn b\xE9n ng\xF3t h\xE0."
  - "Th\xF4i, chu\u1EA9n b\u1ECB \u0111\u1ED3 \u0111\u1EA1c r\u1ED3i hai \xF4ng ch\xE1u
    m\xECnh xu\u1ED1ng xu\u1ED3ng \u0111i con. \u0110\u1EE9ng \u0111\xE2y n\u1EAFng
    l\xEAn n\xF3ng l\u1EAFm."
  - "B\u01B0\u1EDBc xu\u1ED1ng chi\u1EBFc xu\u1ED3ng d\u01B0\u1EDBi b\u1EBFn n\u01B0\u1EDBc
    kia k\xECa, \xF4ng ch\xE8o \u0111\u01B0a \u0111i."
  finalWaitingDialogue:
  - "Mau xu\u1ED1ng xu\u1ED3ng \u0111i con, \xF4ng ch\xE8o \u0111\u01B0a con \u0111i
    s\xE2u v\xE0o r\u1EEBng tr\xE0m m\xE1t l\u1EAFm."
